# LLM 백엔드 (OpenAI 호환). 항상 실제 LLM 재실행 (mock 백엔드 없음).
# 실측 시 실제 OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4.1-nano   (또는 gpt-4o-mini)
#   LLM_API_KEY=sk-...
# 로컬은 mlx-openai-server 등 OpenAI 호환 엔드포인트 사용:
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=gpt-4o-mini
MAX_CONCURRENCY=8
# 재현성 고정 seed (참가자 비노출). 기본 42.
# LLM_SEED=42
# 데이터 경로 override (기본: 상위 repo의 data/)
# GRADER_DATA_DIR=/abs/path/to/data
